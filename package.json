    "@ethersproject/providers": "^5.7.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@snapshot-labs/eslint-config": "^0.1.0-beta.21",
    "@snapshot-labs/prettier-config": "^0.1.0-beta.19",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.0",
    "@types/node": ">=22.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^8.28.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prettier": "^2.7.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.0"
